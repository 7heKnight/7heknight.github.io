---
import BaseLayout from './BaseLayout.astro';
import { CATEGORIES } from '../content/config';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  date: Date;
  category: keyof typeof CATEGORIES;
  tags: string[];
  difficulty: string;
  source: string;
  excerpt: string;
  draft: boolean;
  headings: MarkdownHeading[];
  prev?: { slug: string; title: string } | null;
  next?: { slug: string; title: string } | null;
  related?: { slug: string; title: string }[];
}
const {
  title, date, category, tags, difficulty, source, excerpt, draft,
  headings, prev, next, related = [],
} = Astro.props;
const toc = headings.filter((h) => h.depth === 2 || h.depth === 1);
const dateStr = date.toISOString().slice(0, 10);
---
<BaseLayout title={title} description={excerpt}>
  <div class="container">
    <div class="writeup">
      <aside class="toc">
        <h4>Contents</h4>
        <ul>
          {toc.map((h) => (
            <li style={`padding-left:${(h.depth - 1) * 10}px`}>
              <a href={`#${h.slug}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </aside>

      <article class="post">
        <h1>{title}</h1>
        <p class="post-meta">{dateStr} &middot; {source} &middot; <span class={`badge ${difficulty}`}>{difficulty}</span></p>
        {draft && <p class="post-meta"><span class="badge draft">draft / incomplete</span></p>}
        <div class="post-tags">
          {tags.map((t) => <a class="tag" href={`/tags/${t.toLowerCase()}/`}>#{t}</a>)}
        </div>
        <div class="body">
          <slot />
        </div>
        <nav class="post-nav">
          {prev ? <a href={`/writeups/${prev.slug}/`}>&larr; {prev.title}</a> : <span></span>}
          {next ? <a href={`/writeups/${next.slug}/`} style="text-align:right">{next.title} &rarr;</a> : <span></span>}
        </nav>
      </article>

      <aside class="meta-side">
        <div class="block">
          <h4>Category</h4>
          <a class="tag" href={`/categories/${category}/`}>{CATEGORIES[category]}</a>
        </div>
        {related.length > 0 && (
          <div class="block related">
            <h4>Related</h4>
            {related.map((r) => <a href={`/writeups/${r.slug}/`}>{r.title}</a>)}
          </div>
        )}
      </aside>
    </div>
  </div>
</BaseLayout>
