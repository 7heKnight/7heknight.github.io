---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About">
  <div class="container">
    <section class="hero"><h1>$ whoami</h1></section>

    <section class="about-card">
      <h2>👋 Hi, I'm 7heKnight</h2>
      <p>
        I'm <strong>Ly Tuan Kiet</strong>, a security professional working
        in penetration testing and red teaming. This blog is my notebook
        for binary exploitation and CTF — I break things to understand
        them, then write the process down.
      </p>
    </section>

    <section class="about-card">
      <h2>🎯 Focus</h2>
      <ul>
        <li><strong>Binary exploitation</strong> — stack smashing, ret2libc, ROP.</li>
        <li><strong>Mitigation bypass</strong> — DEP/NX, ASLR, stack canaries.</li>
        <li><strong>Shellcoding</strong> — x86/x64 Linux, Windows.</li>
        <li><strong>CTF</strong> — pwnable.kr and similar pwn challenges.</li>
        <li><strong>Web &amp; mobile pentest</strong> — OWASP-driven testing, Android traffic interception, SSL pinning bypass.</li>
        <li><strong>Vuln research</strong> — CVE reproduction and PoC development.</li>
      </ul>
    </section>

    <section class="about-card">
      <h2>🛠️ Toolbox</h2>
      <ul>
        <li><strong>Debugging:</strong> GDB + peda/pwndbg, Immunity Debugger, WinDbg.</li>
        <li><strong>Exploitation:</strong> pwntools, ROPgadget, msfvenom, Frida, Burp Suite.</li>
        <li><strong>Languages:</strong> Python, C, C++, C#/.NET, Java, x86 assembly.</li>
        <li><strong>Domains:</strong> web app &amp; API security, Android, Active Directory, Linux, TLS/cryptography.</li>
      </ul>
    </section>

    <section class="about-card">
      <h2>📫 Get in touch</h2>
      <p>
        Found a mistake in a writeup or want to collaborate? Reach me at
        <a href="mailto:7h3knight@gmail.com">7h3knight@gmail.com</a>,
        <a href="https://github.com/7heKnight" target="_blank" rel="noopener">GitHub</a>,
        or <a href="https://www.linkedin.com/in/7heknight/" target="_blank" rel="noopener">LinkedIn</a>.
      </p>
      <p style="color:var(--muted);font-size:.9rem">
        ⚠️ Everything here is for educational and authorized testing only.
        See the <a href="/copyright/">copyright &amp; usage policy</a>.
      </p>
    </section>
  </div>
</BaseLayout>
