---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CATEGORIES } from '../../content/config';

const posts = await getCollection('writeups');
const byCat = Object.entries(CATEGORIES).map(([slug, label]) => ({
  slug,
  label,
  items: posts
    .filter((p) => p.data.category === slug)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
})).filter((c) => c.items.length > 0);
---
<BaseLayout title="Categories">
  <div class="container">
    <section class="hero">
      <h1>$ ls categories/</h1>
      <p>Writeups grouped by exploitation technique.</p>
    </section>
    {byCat.map((c) => (
      <section class="section-card" id={c.slug}>
        <h2><a href={`/categories/${c.slug}/`}>{c.label}</a></h2>
        <ul>
          {c.items.map((p) => (
            <li>
              <a href={`/writeups/${p.slug}/`}>{p.data.title}</a>
              <span class="date"> &mdash; {p.data.date.toISOString().slice(0, 10)}</span>
              {p.data.draft && <span class="badge draft" style="margin-left:8px">draft</span>}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
