---
import { getCollection } from 'astro:content';
import RedteamLayout from '../../layouts/RedteamLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('redteam');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();
const d = post.data;
---
<RedteamLayout
  title={d.title}
  date={d.date}
  category={d.category}
  tags={d.tags}
  difficulty={d.difficulty}
  excerpt={d.excerpt}
  draft={d.draft}
  headings={headings}
>
  <Content />
</RedteamLayout>
