---
const { pathname } = Astro.url;
const isActive = (p: string) =>
  p === '/' ? pathname === '/' : pathname.startsWith(p);
---
<header class="site-header">
  <div class="container">
    <a href="/" class="brand"><span class="prompt">7he</span>Knight<span class="prompt">$</span></a>
    <nav class="nav-links">
      <a href="/" aria-current={pathname === '/' ? 'page' : undefined}>Home</a>
      <a href="/writeups/" aria-current={isActive('/writeups') || isActive('/categories') ? 'page' : undefined}>Writeups</a>
      <a href="/pentest/" aria-current={isActive('/pentest') ? 'page' : undefined}>Pentest</a>
      <a href="/redteam/" aria-current={isActive('/redteam') ? 'page' : undefined}>Red Team</a>
      <a href="/tags/" aria-current={isActive('/tags') ? 'page' : undefined}>Tags</a>
      <a href="/about/" aria-current={isActive('/about') ? 'page' : undefined}>About</a>
    </nav>
  </div>
</header>
